### 7.7 Category Versioning + Recurrence Detection

```python
def find_matching_category(new_extraction, user_id) -> str | None:
    hits = search_qdrant(f"memory_{user_id}",
                         embed(new_extraction["summary"]),
                         score_threshold=settings.recurrence_similarity_threshold)
    for hit in hits:
        existing = {e["canonical_name"] for e in hit.payload["named_entities"]}
        new      = {e["name"]           for e in new_extraction["named_entities"]}
        overlap  = len(existing & new) / max(len(existing | new), 1)
        if overlap >= settings.recurrence_entity_overlap_threshold:
            return hit.id
    return None

# hash = sha256(sorted(member_point_ids) + embed_model)[:16]
# only re-embed + re-upsert if hash changed
