**Tier 2: Routing Decision**

```python
def route_result(evaluation: dict, result: dict, user_id: str):

    if evaluation["requires_immediate_bypass"]:
        # create alert, skip discovery queue
        create_alert(
            user_id=user_id,
            scan_id=result["id"],
            alert_type=evaluation["alert_type"],
            severity="critical",
            title=result["title"],
            summary=result["snippet"],
            source_url=result["url"],
            affected_geography=settings.operator_geography,
            affected_infrastructure=evaluation["matching_entities"]
        )
        deliver_alert_immediately(user_id)
        return

    if evaluation["relevance_score"] >= settings.scout_relevance_threshold:
        # write to sandboxed horizon_scan collection
        upsert_horizon_scan(
            user_id=user_id,
            result=result,
            evaluation=evaluation,
            status="new"
        )
        # add to discovery queue for daily digest
        enqueue_discovery(user_id, result["id"])
        return

    # below threshold: discard silently (log to debug only)
    log_debug(f"scout: discarded [{evaluation['relevance_score']:.2f}] {result['title']}")
