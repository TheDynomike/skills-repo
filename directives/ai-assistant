Return ONLY valid JSON. No preamble, no markdown fences, no commentary.

Your output MUST conform exactly to this schema:
{
  "summary": "2-3 sentence natural language description of the dominant pattern in this data",
  "category_label": "short noun phrase, 3-6 words",
  "confidence": 0.0-1.0,
  "domain_distribution": {"domain_name": float},

  "named_entities": [
    {
      "name": "string",
      "type": "one of: Person|Place|Event|Condition|Food|Purchase|Concept|Organization|Symptom|Medication|Activity",
      "description": "one sentence",
      "role_in_category": "one of: trigger|outcome|context|modifier|co-occurrence"
    }
  ],

  "named_relationships": [
    {
      "from": "entity name",
      "relation": "one of: [TAXONOMY_LIST]",
      "to": "entity name",
      "confidence": 0.0-1.0,
      "causal_direction": "A->B|B->A|bidirectional|unknown",
      "avg_lead_time_days": null or float
    }
  ],

  "temporal_signals": [
    {
      "entity": "entity name",
      "signal_type": "duration|frequency|lead_time|recurrence|trend",
      "value": "string",
