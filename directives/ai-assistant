### 10.2 Retrieval Paths

```python
async def query(
    question: str,
    user_id: str,
    top_k: int = 5,
    domain_filter: str = None,
    time_range: dict = None,
    include_raw: bool = False,
    drill_entity: str = None,
    include_predictions: bool = True,
    include_horizon: bool = False,   # horizon never included by default
) -> RetrievalResult:

    q_type = classify_query(question)
    q_vector = embed(question)

    # Layer 0: memory categories
    memory_hits = route_memory_query(q_type, q_vector, user_id, top_k, time_range)

    # Layer 1: trends (from entity registry, not LLM)
    trend_hits = []
    if q_type in ("longitudinal", "predictive", "current"):
        trend_hits = get_entity_trends(user_id, entities_from_hits(memory_hits))

    # Layer 2: predictions (separate collection)
    prediction_hits = []
    if include_predictions and q_type in ("predictive", "current"):
        prediction_hits = search_qdrant(
            f"predictions_{user_id}", q_vector, limit=top_k,
            filter={"status": "pending"}
        )

    # Layer 3: horizon scan (explicit opt-in only)
    horizon_hits = []
    if include_horizon and q_type == "horizon":
        horizon_hits = search_qdrant(
            f"horizon_scan_{user_id}", q_vector, limit=top_k,
            filter={"status": "new"}
        )

    # optional drill
    connected_categories = []
    if drill_entity:
        connected_categories = traverse_entity(drill_entity, user_id, hops=2)

    raw_snippets = []
    if include_raw:
        raw_snippets = search_qdrant(
            f"raw_ingest_{user_id}", q_vector, limit=3,
            filter={"memory_agent_seen": True}
        )

    return RetrievalResult(
        query_type=q_type,
        user_id=user_id,
        memory_categories=[format_memory_hit(h) for h in memory_hits],
        trend_summaries=[format_trend(t) for t in trend_hits],
        active_predictions=[format_prediction(p) for p in prediction_hits],
        horizon_items=[format_horizon(h) for h in horizon_hits],
        connected_categories=connected_categories,
        raw_snippets=[r.payload["raw_text"] for r in raw_snippets],
        drill_available=True,
        retrieved_at=datetime.utcnow().isoformat()
    )
```

### 10.3 Multi-hop Traversal (application code)

```python
def traverse_entity(entity_name: str, user_id: str, hops: int = 2) -> list:
    visited = set()
    frontier = {entity_name}
    results = []

    for _ in range(hops):
        new_categories = []
        for entity in frontier:
            hits = search_qdrant(f"memory_{user_id}", embed(entity), limit=5)
            hits = [h for h in hits
                    if any(e["canonical_name"] == entity
                           for e in h.payload["named_entities"])]
            new_categories.extend(hits)

        new_categories = [c for c in new_categories if c.id not in visited]
        visited.update(c.id for c in new_categories)
        results.extend(new_categories)

        frontier = {e["canonical_name"]
                    for c in new_categories
                    for e in c.payload["named_entities"]}

    return results
```

