## 7. Phase 6 — Retrieval Engine

### 7.1 Query Classifier

Before executing any retrieval, classify the query type. This determines the execution path.

```python
QUERY_TYPES = {
    "current":       ["right now", "currently", "today", "am i", "what's happening"],
    "retrospective": ["ago", "last week", "last month", "in january", "when did", "used to"],
    "predictive":    ["will", "going to", "likely", "predict", "expect", "pattern suggests"],
    "causal":        ["why", "what causes", "what triggers", "because of", "led to"],
    "longitudinal":  ["over time", "trend", "changing", "getting better", "getting worse"],
    "drill":         ["show me", "give me details", "more about", "what exactly"],
}

def classify_query(question: str) -> str:
    question_lower = question.lower()
    for qtype, signals in QUERY_TYPES.items():
        if any(s in question_lower for s in signals):
            return qtype
    return "semantic"  # default: vector similarity
```

### 7.2 Retrieval Paths

```python
async def query(
    question: str,
    user_id: str,
    top_k: int = 5,
    domain_filter: str = None,
    time_range: dict = None,
    include_raw: bool = False,
    drill_entity: str = None
) -> RetrievalResult:

    q_type = classify_query(question)
    q_vector = embed(question)

    if q_type == "current":
        memory_hits = search_qdrant(
            f"memory_{user_id}", q_vector, limit=top_k,
            filter={"current_status": "active"}
        )

    elif q_type == "retrospective":
        # extract time reference from question (regex or small LLM call)
        time_window = extract_time_reference(question)
        memory_hits = search_qdrant(
            f"memory_{user_id}", q_vector, limit=top_k,
            filter={"temporal.time_range.earliest": {"lte": time_window["end"]},
                    "temporal.time_range.latest":   {"gte": time_window["start"]}}
        )

    elif q_type == "predictive":
        memory_hits = search_qdrant(
            f"memory_{user_id}", q_vector, limit=top_k,
            filter={"predictions": {"status": "pending", "confidence": {"gte": 0.65}}}
        )

    elif q_type == "longitudinal":
        # get all versions of matching categories
        memory_hits = search_qdrant(f"memory_{user_id}", q_vector, limit=top_k)
        # sort versions by timestamp within each hit

    elif q_type == "causal":
        # focus on named_relationships with causal types
        memory_hits = search_qdrant(
            f"memory_{user_id}", q_vector, limit=top_k * 2
        )
        memory_hits = filter_by_relationship_types(
            memory_hits, ["TRIGGERS", "CAUSES", "WORSENS", "PRECEDES"]
        )[:top_k]

    else:  # semantic default
        memory_hits = search_qdrant(f"memory_{user_id}", q_vector, limit=top_k)

    # apply domain filter if provided
    if domain_filter:
        memory_hits = [h for h in memory_hits
                       if h.payload["domain_distribution"].get(domain_filter, 0) >= 0.3]

    # optional: drill into raw_ingest for source material
    raw_hits = []
    if include_raw:
        raw_hits = search_qdrant(
            f"raw_ingest_{user_id}", q_vector, limit=3,
            filter={"memory_agent_seen": True}
        )

    # optional: multi-hop entity traversal
    connected_categories = []
    if drill_entity:
        connected_categories = traverse_entity(drill_entity, user_id, hops=2)

    return RetrievalResult(
        query_type=q_type,
        memory_categories=[format_memory_hit(h) for h in memory_hits],
        connected_categories=connected_categories,
        raw_snippets=[r.payload["raw_text"] for r in raw_hits],
        drill_available=True,
        user_id=user_id
    )
```

### 7.3 Multi-hop Traversal (application-level, no graph DB)

```python
def traverse_entity(entity_name: str, user_id: str, hops: int = 2) -> list:
    visited_categories = set()
    frontier_entities = {entity_name}
    results = []

    for hop in range(hops):
        # find categories containing any entity in frontier
        new_categories = []
        for entity in frontier_entities:
            hits = search_qdrant(
                f"memory_{user_id}",
                query_vector=embed(entity),
                limit=5
            )
            # filter to categories that actually name this entity
            hits = [h for h in hits
                    if any(e["canonical_name"] == entity
                           for e in h.payload["named_entities"])]
            new_categories.extend(hits)

        # deduplicate
        new_categories = [c for c in new_categories
                          if c.id not in visited_categories]
        visited_categories.update(c.id for c in new_categories)
        results.extend(new_categories)

        # expand frontier: collect all entities from new categories
        frontier_entities = set()
        for cat in new_categories:
            for e in cat.payload["named_entities"]:
                frontier_entities.add(e["canonical_name"])

    return results
```

