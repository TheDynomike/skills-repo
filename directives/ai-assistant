def register_user(user_id: str):
    # validate user_id: alphanumeric + underscore only, max 32 chars
    assert re.match(r'^[a-z0-9_]{1,32}$', user_id), "invalid user_id"

    collections_to_create = [
        f"raw_ingest_{user_id}",
        f"memory_{user_id}",
        f"entity_registry_{user_id}",
    ]

    for name in collections_to_create:
        if not collection_exists(name):
            create_collection(name, settings.embed_dim)
            write_sentinel(name, settings.embed_model, settings.embed_dim)
        else:
            verify_sentinel(name, settings.embed_model, settings.embed_dim)

    # create drop zone directory
    os.makedirs(f"./drop/{user_id}/processed", exist_ok=True)
    os.makedirs(f"./drop/{user_id}/failed", exist_ok=True)

    # register memory agent for this user in Celery
    register_agent_schedule(user_id)
    
    log(f"user {user_id} registered successfully")
