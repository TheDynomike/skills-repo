            limit=5,
            score_threshold=0.75,
            filter={"timestamp": {"gte": pred.predicted_at}}
        )

        if evidence:
            update_prediction_status(pred.id, "confirmed",
                resolution_evidence=[e.id for e in evidence])
            # confirmed predictions increase parent category confidence
            increment_category_confidence(pred.category_id, delta=0.05)
        # else: leave as PENDING until expiry
