### 6.5 Relationship Taxonomy

```python
RELATIONSHIP_TAXONOMY = {
    "causal":        ["TRIGGERS", "CAUSES", "WORSENS", "IMPROVES", "PREVENTS", "RELIEVES"],
    "temporal":      ["PRECEDES", "FOLLOWS", "COINCIDES_WITH", "PREDICTS", "CORRELATES_WITH"],
    "transactional": ["PURCHASED", "CONSUMED", "USED", "AVOIDED"],
    "social":        ["INTERACTED_WITH", "MENTIONED", "SUPPORTED_BY", "CONFLICTED_WITH"],
    "categorical":   ["IS_TYPE_OF", "BELONGS_TO", "CATEGORIZED_AS", "ASSOCIATED_WITH"],
    "health":        ["EXPERIENCED", "AGGRAVATED_BY", "RELIEVED_BY", "COMORBID_WITH"],
    "behavioral":    ["PERFORMED", "ATTEMPTED", "HABITUAL_WITH", "REACTIVE_TO"],
}

FLAT_TAXONOMY = [r for rels in RELATIONSHIP_TAXONOMY.values() for r in rels]
```

**Normalization pass** (runs before any relationship is stored):
```python
def normalize_relationship(raw: str) -> str:
    raw_upper = raw.upper().replace(" ", "_").replace("-", "_")
    if raw_upper in FLAT_TAXONOMY:
        return raw_upper
    # embed raw string, find nearest taxonomy entry
    scores = cosine_similarity(embed(raw), embed_all(FLAT_TAXONOMY))
    best_idx = scores.argmax()
    if scores[best_idx] >= 0.85:
        return FLAT_TAXONOMY[best_idx]
    # fallback
    log_taxonomy_miss(raw, scores[best_idx])
    return "ASSOCIATED_WITH"
```

### 6.6 Entity Registry — Canonical Identity

For each named entity in the extraction output:

```python
def resolve_entity(name: str, type: str, description: str, user_id: str) -> dict:

    # 1. check shared registry (vector search + levenshtein)
    shared_hits = search_qdrant(
        "shared_entity_registry",
        query_vector=embed(f"{type}: {name}"),
        limit=5, score_threshold=settings.dedup_similarity_threshold
    )
    shared_hits = [h for h in shared_hits
                   if levenshtein(h.payload["canonical_name"].lower(), name.lower())
                   <= settings.dedup_levenshtein_max
                   or cosine_sim(embed(h.payload["canonical_name"]), embed(name)) >= settings.dedup_similarity_threshold]

    if shared_hits:
        shared_entity = shared_hits[0]
        # add alias if name variant not already known
        if name not in shared_entity.payload["aliases"]:
            append_alias(shared_entity.id, name)
        shared_id = shared_entity.id
        canonical_name = shared_entity.payload["canonical_name"]
    else:
        # create in shared registry
        shared_id = f"entity_{uuid4()}"
        upsert_shared_entity(shared_id, name, type, description)
        canonical_name = name

    # 2. check personal registry
    personal_hit = get_personal_entity(user_id, shared_id)

    if personal_hit:
        update_personal_entity_stats(user_id, shared_id)
        personal_id = personal_hit.id
    else:
        personal_id = create_personal_entity(user_id, shared_id, canonical_name, type)

    return {
        "shared_entity_id": shared_id,
        "personal_entity_id": personal_id,
        "canonical_name": canonical_name
    }
```

### 6.7 Category Versioning + Recurrence Detection

Before creating a new memory category, check for an existing one:

```python
def find_matching_category(new_extraction: dict, user_id: str) -> str | None:
    # embed the new summary
    # search memory_{user_id}
    hits = search_qdrant(
        f"memory_{user_id}",
        query_vector=embed(new_extraction["summary"]),
        limit=5, score_threshold=settings.recurrence_similarity_threshold
    )
    for hit in hits:
        # check entity overlap
        existing_entities = {e["canonical_name"] for e in hit.payload["named_entities"]}
        new_entities = {e["name"] for e in new_extraction["named_entities"]}
        overlap = len(existing_entities & new_entities) / max(len(existing_entities | new_entities), 1)
        if overlap >= settings.recurrence_entity_overlap_threshold:
            return hit.id  # recurrence of this category
    return None  # new category
```

**If recurrence detected:** add new version to existing category. Update `recurrence_count`, `cycles`, `avg_cycle_duration_days`, `avg_gap_between_cycles_days`. Recompute `predicted_resolution`.

**If new category:** create with version 1.

**Hash computation:**
```python
import hashlib, json

def compute_category_hash(member_point_ids: list, embed_model: str) -> str:
    content = json.dumps({
        "ids": sorted(member_point_ids),
        "embed_model": embed_model,
    }, sort_keys=True)
    return hashlib.sha256(content.encode()).hexdigest()[:16]
```

Only re-embed and re-upsert a category if the hash changed. Pass existing summary + new points for incremental updates, not full re-extraction.

